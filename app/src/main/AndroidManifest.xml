<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- REGLA DE ORO: PERMISOS FUERA DE <application> -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FincApp"
        tools:targetApi="31">

        <!-- Pantalla de Login (Launcher) -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Otras Actividades -->
        <activity android:name=".MenuPrincipalActivity" android:exported="false" />
        <activity android:name=".GestionComunidadActivity" android:exported="false" />
        <activity android:name=".TablonAnunciosActivity" android:exported="false" />
        <activity android:name=".DatosPerfilActivity" android:exported="false" />
        <activity android:name=".VotacionesActivity" android:exported="false" />
        <activity
            android:name=".VotacionesActivasActivity"
            android:exported="false"
            android:label="Votaciones Activas" />
        <activity android:name=".VotacionesFinalizadasActivity" android:exported="false" />
        <activity android:name=".ContactoActivity" android:exported="false" />

    </application>

</manifest>