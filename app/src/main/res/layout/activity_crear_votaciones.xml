<?xml version="1.0" encoding="utf-8"?>

<!--
    PANTALLA: Creación de Votaciones
    DESCRIPCIÓN: Interfaz que permite crear nuevas votaciones por el administrador.

-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nueva Votación"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginBottom="24dp"
        android:gravity="center" />

    <!-- Selector de Comunidad -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Seleccionar Comunidad"
        android:textColor="#666666"
        android:layout_marginBottom="8dp" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        android:layout_marginBottom="16dp">

        <Spinner
            android:id="@+id/spinnerComunidadesVotacion"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:padding="8dp" />
    </androidx.cardview.widget.CardView>

    <!-- Título de la Votación -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Título del asunto"
        android:textColor="#666666"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etTituloVotacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ej: Pintar fachada"
        android:background="@android:drawable/edit_text"
        android:padding="12dp"
        android:inputType="textCapSentences"
        android:layout_marginBottom="16dp" />

    <!-- Descripción -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Descripción detallada"
        android:textColor="#666666"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etDescripcionVotacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Explica los detalles de la propuesta..."
        android:background="@android:drawable/edit_text"
        android:padding="12dp"
        android:gravity="top"
        android:lines="5"
        android:inputType="textMultiLine"
        android:layout_marginBottom="24dp" />

    <!-- Botón Guardar -->
    <Button
        android:id="@+id/btnGuardarVotacion"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="PUBLICAR VOTACIÓN"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2196F3"
        android:textStyle="bold"
        app:cornerRadius="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Al publicar, todos los vecinos de la comunidad seleccionada recibirán la propuesta."
        android:textSize="12sp"
        android:textColor="#999999"
        android:gravity="center"
        android:layout_marginTop="16dp" />

</LinearLayout>