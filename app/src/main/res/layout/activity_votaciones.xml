<?xml version="1.0" encoding="utf-8"?>
<!--
    PANTALLA: Selección de Votaciones
    DESCRIPCIÓN: Menú intermedio para elegir entre consultas en curso o historial.

-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A242F"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- TÍTULOS DE CABECERA -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Votaciones"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selecciona el estado de las consultas"
        android:textColor="#A0AEC0"
        android:textSize="16sp"
        android:layout_marginBottom="40dp" />

    <!-- TARJETA: VOTACIONES ACTIVAS -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardActivas"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginBottom="20dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground"
        app:cardBackgroundColor="#2D3748"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="20dp">

            <TextView
                android:id="@+id/btnActivas"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:text="VOTACIONES ACTIVAS"
                android:textColor="#63B3ED"
                android:textSize="18sp"
                android:textStyle="bold" />


        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <!-- TARJETA: VOTACIONES FINALIZADAS -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardFinalizadas"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginBottom="40dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground"
        app:cardBackgroundColor="#2D3748"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp">

        <TextView
            android:id="@+id/btnFinalizadas"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="VOTACIONES FINALIZADAS"
            android:textColor="#A0AEC0"
            android:textSize="18sp"
            android:textStyle="bold" />
    </androidx.cardview.widget.CardView>

    <!-- ENLACE DE RETORNO -->
    <TextView
        android:id="@+id/txtVolver"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="← Volver al menú"
        android:textColor="#CBD5E0"
        android:textSize="16sp"
        android:padding="12dp" />

</LinearLayout>