<?xml version="1.0" encoding="utf-8"?>
<!--
    PANTALLA: Inicio de Sesión (Login)
    DESCRIPCIÓN: Formulario de acceso .

-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#1A242F">

    <!-- Icono -->
    <TextView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="@android:drawable/dialog_holo_light_frame"
        android:backgroundTint="#3182CE"
        android:text="F"
        android:textColor="#FFFFFF"
        android:textSize="40sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FincApp"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="4dp"
        android:letterSpacing="0.02"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tu comunidad, siempre contigo"
        android:textSize="15sp"
        android:textColor="#A0AEC0"
        android:layout_marginBottom="48dp"/>


    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Correo electrónico"
        android:textColorHint="#718096"
        app:hintTextColor="#3182CE"
        app:boxStrokeColor="#3182CE"
        app:boxBackgroundColor="#2D3748"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_marginBottom="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textEmailAddress"
            android:textColor="#FFFFFF"
            android:padding="16dp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- CONTENEDOR CONTRASEÑA: Incluye el toggle para ver/ocultar caracteres -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Contraseña"
        android:textColorHint="#718096"
        app:hintTextColor="#3182CE"
        app:boxStrokeColor="#3182CE"
        app:boxBackgroundColor="#2D3748"
        app:passwordToggleEnabled="true"
        app:passwordToggleTint="#A0AEC0"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_marginBottom="32dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword"
            android:textColor="#FFFFFF"
            android:padding="16dp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Botón de acción principal -->
    <Button
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="INICIAR SESIÓN"
        android:backgroundTint="#3182CE"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="12dp"
        android:elevation="4dp" />

    <TextView
        android:id="@+id/tvOlvidePass"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¿Problemas para entrar? Recuperar contraseña"
        android:textColor="#A0AEC0"
        android:layout_marginTop="32dp"
        android:textSize="13sp"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>